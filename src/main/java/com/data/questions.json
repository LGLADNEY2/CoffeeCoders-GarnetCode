        "solutions": [
            {
                "authorID": "4460fe58-54de-4eba-b277-72724d408588",
                "language": "JAVA",
                "title": "Two Pointer Solution",
                "segments": [
                    {
                        "title": "Code",
                        "desc": "",
                        "dataType": "CODE",
                        "data": "class ReverseString {\n    public void reverseString(char[] s) {\n        int left = 0;\n        int right = s.length - 1;\n\n        while (left < right) {\n            char temp = s[left];\n            s[left] = s[right];\n            s[right] = temp;\n            left++;\n            right--;\n        }\n    }\n}"
                    }
                ],
                "comments": [],
