        "solutions": [
            {
                "authorID":"4460fe58-54de-4eba-b277-72724d408588",
                "language":"JAVA",
                "title":"Java Two Sum Solution",
                "segments":[
                    {
                    "title": "Intuition",
                    "desc": "We want two numbers that add to target. Instead of checking every pair, we can store numbers we’ve already seen.",
                    "dataType": "STRING",
                    "data": ""
                    },
                    {
                    "title": "Code",
                    "desc": "",
                    "dataType": "CODE",
                    "data": "import java.util.HashMap;\n\nclass TwoSum {\n    public int[] twoSum(int[] nums, int target) {\n        HashMap<Integer, Integer> map = new HashMap<>();\n\n        for (int i = 0; i < nums.length; i++) {\n            int complement = target - nums[i];\n            if (map.containsKey(complement)) {\n                return new int[]{map.get(complement), i};\n            }\n            map.put(nums[i], i);\n        }\n        return new int[0];\n    }\n}"
                    },
                    {
                    "title": "Complexity",
                    "desc": "Time: O(n), Space: O(n)",
                    "dataType": "STRING",
                    "data": ""
                    }
                ],
                "comments":[],
