        "solutions": [
            {
                "authorID": "4460fe58-54de-4eba-b277-72724d408588",
                "language": "JAVA",
                "title": "Java Palindrome Solution",
                "segments": [
                    {
                        "title": "Code",
                        "desc": "",
                        "dataType": "CODE",
                        "data": "class Palindrome {\n    public boolean isPalindrome(String s) {\n        s = s.replaceAll(\"[^a-zA-Z0-9]\", \"\").toLowerCase();\n        int left = 0, right = s.length() - 1;\n\n        while (left < right) {\n            if (s.charAt(left) != s.charAt(right)) {\n                return false;\n            }\n            left++;\n            right--;\n        }\n        return true;\n    }\n}"
                    }
                ],
