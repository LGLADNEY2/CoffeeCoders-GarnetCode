<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
            prefWidth="984.0" prefHeight="806.0"
            style="-fx-background-color: linear-gradient(to bottom right, #220000 0%, #000000 28%, #220000 100%);"
            fx:controller="com.controllers.QuestionListController">

    <children>
        <BorderPane AnchorPane.topAnchor="0.0" AnchorPane.rightAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                    style="-fx-background-color: transparent;">

            <left>
                <VBox prefWidth="165.0" spacing="16.0"
                      style="-fx-background-color: #a52626; -fx-background-radius: 18; -fx-border-radius: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 14, 0.2, 0, 2);">
                    <padding>
                        <Insets top="34" right="16" bottom="24" left="20"/>
                    </padding>

                    <Label text="GARNETCODE"
                           style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>

                    <VBox spacing="18.0" style="-fx-padding: 16 0 0 0;">
                        <Button text="⌂   Dashboard" onAction="#goToDashboard"
                            style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: normal; -fx-alignment: CENTER_LEFT; -fx-padding: 0; -fx-cursor: hand;"/>
                        <Button text="♡   Favorites"
                            style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: normal; -fx-alignment: CENTER_LEFT; -fx-padding: 0; -fx-cursor: hand;"/>
                        <Button text="▣   Questions" onAction="#goToQuestions"
                            style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: normal; -fx-alignment: CENTER_LEFT; -fx-padding: 0; -fx-cursor: hand; -fx-underline: true;"/>
                        <Button text="＋   Create" onAction="#goToCreate"
                            style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: normal; -fx-alignment: CENTER_LEFT; -fx-padding: 0; -fx-cursor: hand;"/>
                    </VBox>
                    <Region VBox.vgrow="ALWAYS"/>
                </VBox>
            </left>

            <center>
                <VBox spacing="12.0" style="-fx-background-color: transparent;">
                    <padding>
                        <Insets top="18" right="20" bottom="18" left="18"/>
                    </padding>

                    <!-- Search and filters -->
                    <HBox spacing="10.0" alignment="CENTER_LEFT"
                          style="-fx-background-color: #b82e2e; -fx-background-radius: 12; -fx-border-radius: 12;">
                        <padding>
                            <Insets top="10" right="12" bottom="10" left="12"/>
                        </padding>

                        <Label text="⌕" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                        <TextField promptText="Search for problems here..."
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.65); -fx-background-insets: 0; -fx-border-color: transparent;"/>

                        <HBox spacing="10.0" alignment="CENTER_RIGHT">
                            <Label text="Category" style="-fx-text-fill: white; -fx-font-size: 11px; -fx-background-color: #8f2020; -fx-background-radius: 999; -fx-padding: 8 16;"/>
                            <Label text="Language" style="-fx-text-fill: white; -fx-font-size: 11px; -fx-background-color: #8f2020; -fx-background-radius: 999; -fx-padding: 8 16;"/>
                            <Label text="Difficulty" style="-fx-text-fill: white; -fx-font-size: 11px; -fx-background-color: #8f2020; -fx-background-radius: 999; -fx-padding: 8 16;"/>
                            <Label text="Sort" style="-fx-text-fill: white; -fx-font-size: 11px; -fx-background-color: #8f2020; -fx-background-radius: 999; -fx-padding: 8 16;"/>
                        </HBox>
                    </HBox>

                    <!-- Main card area -->
                    <StackPane style="-fx-background-color: #221c1c; -fx-background-radius: 12;">
                        <padding>
                            <Insets top="18" right="18" bottom="18" left="18"/>
                        </padding>

                        <VBox spacing="10.0">
                            <HBox spacing="30.0" style="-fx-padding: 0 8 4 8;">
                                <Label text="PROBLEM TITLE &amp; DATE" style="-fx-text-fill: #f2b0a8; -fx-font-size: 9px; -fx-font-weight: bold;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="CATEGORY" style="-fx-text-fill: #f2b0a8; -fx-font-size: 9px; -fx-font-weight: bold;"/>
                                <Label text="LANGUAGE" style="-fx-text-fill: #f2b0a8; -fx-font-size: 9px; -fx-font-weight: bold;"/>
                                <Label text="CLASS" style="-fx-text-fill: #f2b0a8; -fx-font-size: 9px; -fx-font-weight: bold;"/>
                                <Label text="DIFFICULTY" style="-fx-text-fill: #f2b0a8; -fx-font-size: 9px; -fx-font-weight: bold;"/>
                                <Label text="RATING" style="-fx-text-fill: #f2b0a8; -fx-font-size: 9px; -fx-font-weight: bold;"/>
                            </HBox>

                            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                        style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                                <content>
                                    <VBox fx:id="questionRows" spacing="14.0" style="-fx-background-color: transparent;">
                                        <padding>
                                            <Insets top="0" right="0" bottom="0" left="0"/>
                                        </padding>
                                    </VBox>
                                </content>
                            </ScrollPane>
                        </VBox>
                    </StackPane>
                </VBox>
            </center>
        </BorderPane>
    </children>
</AnchorPane>
