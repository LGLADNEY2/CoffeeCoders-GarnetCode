<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
            prefWidth="984.0" prefHeight="806.0"
            style="-fx-background-color: linear-gradient(to bottom, #000000 0%, #220000 100%);"
            stylesheets="@styles.css"
            fx:controller="com.controllers.QuestionListController">

    <children>
        <BorderPane AnchorPane.topAnchor="0.0" AnchorPane.rightAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                    style="-fx-background-color: transparent;">

            <left>
                <VBox spacing="20" prefWidth="180" alignment="TOP_CENTER" BorderPane.alignment="CENTER"
                      style="-fx-background-color: #a82525; -fx-background-radius: 18px; -fx-padding: 24 0 24 0;">
                    <Label text="GARNETCODE" style="-fx-text-fill: #fff; -fx-font-size: 22px; -fx-font-weight: bold; -fx-padding: 0 0 18 0;" />
                    <VBox spacing="10">
                        <Button text="Dashboard" onAction="#goToDashboard" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 10 0 10 18; -fx-background-radius: 8px; -fx-cursor: hand;" />
                        <Button text="Favorites" onAction="#goToFavorites" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 10 0 10 18; -fx-background-radius: 8px; -fx-cursor: hand;" />
                        <Button text="Questions" onAction="#goToQuestions" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 10 0 10 18; -fx-background-radius: 8px; -fx-cursor: hand; -fx-underline: true;" />
                        <Button text="Create" onAction="#goToCreate" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 10 0 10 18; -fx-background-radius: 8px; -fx-cursor: hand;" />
                    </VBox>
                </VBox>
            </left>

            <center>
                <VBox alignment="TOP_CENTER" spacing="20" style="-fx-background-color: #23201e; -fx-background-radius: 18px; -fx-padding: 32 32 32 32; -fx-effect: dropshadow(gaussian, #00000055, 16, 0.2, 0, 4);">
                    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: transparent; -fx-padding: 0 0 18 0;">
                        <TextField promptText="Search for problems here..." HBox.hgrow="ALWAYS" prefWidth="1000"
                                   style="-fx-background-color: #a82525; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-background-radius: 24px; -fx-padding: 10 18 10 18; -fx-prompt-text-fill: #fff8; -fx-border-width: 0;" />
                    </HBox>

                    <VBox spacing="10" styleClass="section">
                        <Label alignment="CENTER" maxWidth="1.7976931348623157E308" style="-fx-text-fill: #f5f5f5; -fx-font-size: 18px; -fx-font-weight: bold;" styleClass="section-title" text="Questions" textAlignment="CENTER" />
                        <TableView fx:id="questionTable" styleClass="problem-table">
                            <columns>
                                <TableColumn fx:id="listTitleDate" text="Problem Title / Date" />
                                <TableColumn fx:id="listCategory" text="Category" />
                                <TableColumn fx:id="listLanguage" text="Language" />
                                <TableColumn fx:id="listClass" text="Class" />
                                <TableColumn fx:id="listDifficulty" text="Difficulty" />
                                <TableColumn fx:id="listRating" text="Rating" />
                            </columns>
                        </TableView>
                    </VBox>
                </VBox>
            </center>
        </BorderPane>
    </children>
</AnchorPane>
