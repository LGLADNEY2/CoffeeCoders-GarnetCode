<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.controllers.SettingsController"
            style="-fx-background-color: linear-gradient(to bottom, #000000 0%, #220000 100%);">
    <left>
        <VBox spacing="20" prefWidth="180" alignment="TOP_CENTER" BorderPane.alignment="CENTER"
              style="-fx-background-color: #a82525; -fx-background-radius: 18px; -fx-padding: 24 0 24 0;">
            <Label text="GARNETCODE" style="-fx-text-fill: #fff; -fx-font-size: 22px; -fx-font-weight: bold; -fx-padding: 0 0 18 0;" />
            <VBox spacing="10">
                <Button text="Dashboard" onAction="#goToDashboard" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 10 0 10 18; -fx-background-radius: 8px; -fx-cursor: hand;" />
                <Button text="Favorites" onAction="#goToFavorites" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 10 0 10 18; -fx-background-radius: 8px; -fx-cursor: hand;" />
                <Button text="Questions" onAction="#goToQuestions" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 10 0 10 18; -fx-background-radius: 8px; -fx-cursor: hand;" />
                <Button text="Create" onAction="#goToCreate" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 10 0 10 18; -fx-background-radius: 8px; -fx-cursor: hand;" />
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="18" alignment="TOP_LEFT" style="-fx-padding: 24 24 24 24;">
            <Label text="Settings" style="-fx-text-fill: #fff; -fx-font-size: 24px; -fx-font-weight: bold;" />
            <Label text="Profile" style="-fx-text-fill: #fff; -fx-font-size: 18px; -fx-font-weight: bold;" />

            <HBox spacing="12">
                <TextField fx:id="firstNameField" promptText="First Name" style="-fx-background-color: #23201e; -fx-text-fill: #fff; -fx-font-size: 15px; -fx-background-radius: 12px; -fx-padding: 8 14 8 14; -fx-border-width: 0;" HBox.hgrow="ALWAYS" />
                <TextField fx:id="lastNameField" promptText="Last Name" style="-fx-background-color: #23201e; -fx-text-fill: #fff; -fx-font-size: 15px; -fx-background-radius: 12px; -fx-padding: 8 14 8 14; -fx-border-width: 0;" HBox.hgrow="ALWAYS" />
            </HBox>

            <TextField fx:id="emailField" promptText="Email" style="-fx-background-color: #23201e; -fx-text-fill: #fff; -fx-font-size: 15px; -fx-background-radius: 12px; -fx-padding: 8 14 8 14; -fx-border-width: 0;" />
            <TextField fx:id="usernameField" promptText="Username" style="-fx-background-color: #23201e; -fx-text-fill: #fff; -fx-font-size: 15px; -fx-background-radius: 12px; -fx-padding: 8 14 8 14; -fx-border-width: 0;" />

            <Button text="Save Profile" onAction="#saveProfile" style="-fx-background-color: #a82525; -fx-text-fill: #fff; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 10px; -fx-padding: 10 18; -fx-cursor: hand;" />

            <Separator />

            <Label text="Display" style="-fx-text-fill: #fff; -fx-font-size: 18px; -fx-font-weight: bold;" />
            <CheckBox fx:id="fullscreenCheck" text="Enable Fullscreen" onAction="#toggleFullscreen" style="-fx-text-fill: #fff; -fx-font-size: 15px;" />

            <Region VBox.vgrow="ALWAYS" />
            <Label fx:id="statusLabel" text="" style="-fx-text-fill: #ffcc8a; -fx-font-size: 14px; -fx-font-style: italic;" />
        </VBox>
    </center>

    <right>
        <VBox spacing="14" alignment="TOP_CENTER" prefWidth="270" style="-fx-padding: 24 8 24 8;">
            <VBox spacing="12" alignment="TOP_LEFT" prefWidth="244"
                  style="-fx-background-color: #1d1a1a; -fx-background-radius: 24px; -fx-padding: 18 14 18 14; -fx-effect: dropshadow(gaussian, #00000088, 18, 0.28, 0, 6);">
                <Label text="Quick Actions" style="-fx-text-fill: #f5f5f5; -fx-font-size: 18px; -fx-font-weight: bold;" />
                <Button text="Log Out" onAction="#logout" style="-fx-background-color: #a82525; -fx-text-fill: #fff; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 10px; -fx-padding: 10 18; -fx-cursor: hand;" />
                <Label text="Tip: You can return to Dashboard using the left menu at any time."
                       wrapText="true"
                       style="-fx-text-fill: #b9b9b9; -fx-font-size: 13px;" />
            </VBox>
        </VBox>
    </right>
</BorderPane>
