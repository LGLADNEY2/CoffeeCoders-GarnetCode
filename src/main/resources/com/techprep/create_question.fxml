<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.controllers.CreateQuestionController"
            style="-fx-background-color: linear-gradient(to bottom, #000000 0%, #220000 100%);">
    <!-- Sidebar -->
    <left>
        <VBox spacing="20" prefWidth="180" alignment="TOP_CENTER" BorderPane.alignment="CENTER"
              style="-fx-background-color: #a82525; -fx-background-radius: 18px; -fx-padding: 24 0 24 0;">
            <Label text="GARNETCODE" style="-fx-text-fill: #fff; -fx-font-size: 22px; -fx-font-weight: bold; -fx-padding: 0 0 18 0;" />
            <VBox spacing="10">
                <Button text="Dashboard" onAction="#goToDashboard" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 10 0 10 18; -fx-background-radius: 8px; -fx-cursor: hand;" />
                <Button text="Favorites" onAction="#goToFavorites" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 10 0 10 18; -fx-background-radius: 8px; -fx-cursor: hand;" />
                <Button text="Questions" onAction="#goToQuestions" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 10 0 10 18; -fx-background-radius: 8px; -fx-cursor: hand;" />
                <Button text="Create" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 10 0 10 18; -fx-background-radius: 8px; -fx-cursor: hand; -fx-underline: true;" />
            </VBox>
        </VBox>
    </left>
    <!-- Main Content -->
    <center>
        <VBox spacing="18" alignment="TOP_CENTER" style="-fx-padding: 24 24 24 24;">
            <Label text="Create A Question" style="-fx-text-fill: #fff; -fx-font-size: 24px; -fx-font-weight: bold; -fx-padding: 0 0 18 0;" />
            <TextField fx:id="titleField" promptText="Title" style="-fx-background-color: #23201e; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-background-radius: 12px; -fx-padding: 8 18 8 18; -fx-border-width: 0;" />
            <HBox spacing="12">
                <TextField fx:id="timeField" promptText="Recommended Time" style="-fx-background-color: #23201e; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-background-radius: 12px; -fx-padding: 8 18 8 18; -fx-border-width: 0;" />
                <TextField fx:id="difficultyField" promptText="Difficulty" style="-fx-background-color: #23201e; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-background-radius: 12px; -fx-padding: 8 18 8 18; -fx-border-width: 0;" />
            </HBox>
            <TextArea fx:id="descriptionField" promptText="Description" prefRowCount="4" style="-fx-background-color: #23201e; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-background-radius: 12px; -fx-padding: 8 18 8 18; -fx-border-width: 0;" />
            <TextField fx:id="hint1Field" promptText="Hint 1" style="-fx-background-color: #23201e; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-background-radius: 12px; -fx-padding: 8 18 8 18; -fx-border-width: 0;" />
            <TextField fx:id="hint2Field" promptText="Hint 2" style="-fx-background-color: #23201e; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-background-radius: 12px; -fx-padding: 8 18 8 18; -fx-border-width: 0;" />
            <TextField fx:id="hint3Field" promptText="Hint 3" style="-fx-background-color: #23201e; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-background-radius: 12px; -fx-padding: 8 18 8 18; -fx-border-width: 0;" />
            <TextArea fx:id="solutionField" promptText="Solution" prefRowCount="4" style="-fx-background-color: #23201e; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-background-radius: 12px; -fx-padding: 8 18 8 18; -fx-border-width: 0;" />
            <Button text="Submit For Review" fx:id="submitButton" onAction="#handleSubmit" style="-fx-background-color: #a82525; -fx-text-fill: #fff; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 12px; -fx-padding: 15 20; -fx-cursor: hand; -fx-margin: 12 0 0 0;" />
        </VBox>
    </center>
</BorderPane>
