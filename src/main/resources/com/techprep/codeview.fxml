<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.BorderPane?>
<?import org.fxmisc.flowless.VirtualizedScrollPane?>
<?import org.fxmisc.richtext.CodeArea?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.controllers.CodeViewController"
            styleClass="codeview-root">

    <center>
        <VBox spacing="10" styleClass="codeview-shell">
            <HBox spacing="8" styleClass="codeview-toolbar" alignment="CENTER_LEFT">
                <Button text="Back" onAction="#goBackToQuestion" styleClass="codeview-toolbar-btn" />
                <Button text="Run" onAction="#runCode" styleClass="codeview-toolbar-btn" />
                <Button text="Submit" onAction="#submitCode" styleClass="codeview-submit-btn" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Open File" onAction="#openFile" styleClass="codeview-toolbar-btn" />
            </HBox>

            <VBox spacing="0" styleClass="codeview-editor-card">
                <Label text="Code" styleClass="codeview-title" />
                <HBox spacing="8" styleClass="codeview-language-row" alignment="CENTER_LEFT">
                    <ComboBox fx:id="languagePicker" promptText="Language" styleClass="codeview-language-picker" />
                    <Label text="Auto" styleClass="codeview-mode-label" />
                </HBox>

                <VirtualizedScrollPane styleClass="codeview-scroll-pane" VBox.vgrow="ALWAYS">
                    <content>
                        <CodeArea fx:id="codeArea" styleClass="codeview-editor" />
                    </content>
                </VirtualizedScrollPane>
            </VBox>
        </VBox>
    </center>

    <stylesheets>
      <URL value="@styles.css" />
   </stylesheets>
</BorderPane>