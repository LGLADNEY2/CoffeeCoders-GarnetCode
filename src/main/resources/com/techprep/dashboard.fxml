<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Arc?>
<?import javafx.scene.shape.Circle?>
<BorderPane fx:id="dashboardRoot" xmlns:fx="http://javafx.com/fxml" fx:controller="com.controllers.DashboardController"
            style="-fx-background-color: linear-gradient(to bottom, #000000 0%, #220000 100%);" stylesheets="@styles.css">
    <!-- Sidebar -->
    <left>
        <VBox spacing="20" prefWidth="180" alignment="TOP_CENTER" BorderPane.alignment="CENTER"
              style="-fx-background-color: #a82525; -fx-background-radius: 18px; -fx-padding: 24 0 24 0;">
            <Label text="GARNETCODE" style="-fx-text-fill: #fff; -fx-font-size: 22px; -fx-font-weight: bold; -fx-padding: 0 0 18 0;" />
            <VBox spacing="10">
                <Button text="Dashboard" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 10 0 10 18; -fx-background-radius: 8px; -fx-cursor: hand; -fx-underline: true;" />
                <Button text="Favorites" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 10 0 10 18; -fx-background-radius: 8px; -fx-cursor: hand;" />
                <Button text="Questions" onAction="#goToQuestions" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 10 0 10 18; -fx-background-radius: 8px; -fx-cursor: hand;" />
                <Button text="Create" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 10 0 10 18; -fx-background-radius: 8px; -fx-cursor: hand;" onAction="#goToCreate" />
            </VBox>
        </VBox>
    </left>
    <!-- Main Content -->
    <center>
          <VBox spacing="20" alignment="TOP_CENTER"
              style="-fx-background-color: #23201e; -fx-background-radius: 18px; -fx-padding: 32 32 32 32; -fx-effect: dropshadow(gaussian, #00000055, 16, 0.2, 0, 4);">
            <!-- Top Bar -->
            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: transparent; -fx-padding: 0 0 18 0;">
                <TextField promptText="Search for problems here..." HBox.hgrow="ALWAYS" prefWidth="1000"
                           style="-fx-background-color: #a82525; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-background-radius: 24px; -fx-padding: 10 18 10 18; -fx-prompt-text-fill: #fff8; -fx-border-width: 0;" />
            </HBox>
            <!-- Sections -->
            <VBox spacing="20" styleClass="sections">
                <!-- Continue Section -->
                <VBox spacing="10" styleClass="section">
                    <Label text="Continue" styleClass="section-title" maxWidth="1.7976931348623157E308" alignment="CENTER" textAlignment="CENTER"
                           style="-fx-text-fill: #f5f5f5; -fx-font-size: 18px; -fx-font-weight: bold;" />
                    <TableView fx:id="continueTable" styleClass="problem-table">
                        <columns>
                            <TableColumn fx:id="conTitleDate" text="Problem Title / Date" />
                            <TableColumn fx:id="conCategory" text="Category" />
                            <TableColumn fx:id="conLanguage" text="Language" />
                            <TableColumn fx:id="conClass" text="Class" />
                            <TableColumn fx:id="conDifficulty" text="Difficulty" />
                            <TableColumn fx:id="conRating" text="Rating" />
                        </columns>
                    </TableView>
                </VBox>
                <!-- Recommended Section -->
                <VBox spacing="10" styleClass="section">
                    <Label text="Recommended" styleClass="section-title" maxWidth="1.7976931348623157E308" alignment="CENTER" textAlignment="CENTER"
                           style="-fx-text-fill: #f5f5f5; -fx-font-size: 18px; -fx-font-weight: bold;" />
                    <TableView fx:id="recommendedTable" styleClass="problem-table">
                        <columns>
                            <TableColumn fx:id="recTitleDate" text="Problem Title / Date" />
                            <TableColumn fx:id="recCategory" text="Category" />
                            <TableColumn fx:id="recLanguage" text="Language" />
                            <TableColumn fx:id="recClass" text="Class" />
                            <TableColumn fx:id="recDifficulty" text="Difficulty" />
                            <TableColumn fx:id="recRating" text="Rating" />
                        </columns>
                    </TableView>
                </VBox>
                <!-- Favorites Section -->
                <VBox spacing="10" styleClass="section">
                    <Label text="Favorites" styleClass="section-title" maxWidth="1.7976931348623157E308" alignment="CENTER" textAlignment="CENTER"
                           style="-fx-text-fill: #f5f5f5; -fx-font-size: 18px; -fx-font-weight: bold;" />
                    <TableView fx:id="favoritesTable" styleClass="problem-table">
                        <columns>
                            <TableColumn fx:id="favTitleDate" text="Problem Title / Date" />
                            <TableColumn fx:id="favCategory" text="Category" />
                            <TableColumn fx:id="favLanguage" text="Language" />
                            <TableColumn fx:id="favClass" text="Class" />
                            <TableColumn fx:id="favDifficulty" text="Difficulty" />
                            <TableColumn fx:id="favRating" text="Rating" />
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </VBox>
    </center>
    <!-- Profile Panel -->
    <right>
                <VBox alignment="TOP_CENTER" prefWidth="270" style="-fx-padding: 18 8 18 8;">
                        <VBox spacing="14" alignment="TOP_CENTER" prefWidth="244"
                                    style="-fx-background-color: #1d1a1a; -fx-background-radius: 24px; -fx-padding: 18 10 18 10; -fx-effect: dropshadow(gaussian, #00000088, 18, 0.28, 0, 6);">

                                <HBox alignment="CENTER_LEFT" prefWidth="224" maxWidth="1.7976931348623157E308" style="-fx-padding: 0 0 2 0;" spacing="4">
                    <children>
                        <Label text="Your Profile" style="-fx-text-fill: #f2f2f2; -fx-font-size: 20px; -fx-font-weight: bold;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <MenuButton text="⋯" popupSide="BOTTOM" styleClass="profile-menu-button">
                            <items>
                                <MenuItem text="⚙  Settings" onAction="#openSettings" />
                                <MenuItem text="⇦  Log out" onAction="#logout" />
                            </items>
                        </MenuButton>
                    </children>
                </HBox>

                <StackPane style="-fx-padding: 4 4 4 4;">
                    <ProgressIndicator progress="0.72" prefWidth="96" prefHeight="96"
                                       style="-fx-progress-color: #f15e67; -fx-control-inner-background: #1d1a1a;" />
                    <ImageView fx:id="profileImage" fitWidth="62" fitHeight="62"
                               style="-fx-effect: dropshadow(gaussian, #000000aa, 8, 0.22, 0, 2);" />
                </StackPane>

                  <Label text="Good Morning,&#10;Cocky!" wrapText="true" textOverrun="CLIP" textAlignment="CENTER" maxWidth="1.7976931348623157E308"
                      style="-fx-text-fill: #f3f3f3; -fx-font-size: 26px; -fx-font-weight: bold; -fx-alignment: center;" />
                <Label text="Continue Your Journey And&#10;Achieve Your Target"
                      wrapText="true" textOverrun="CLIP" textAlignment="CENTER" maxWidth="1.7976931348623157E308"
                      style="-fx-text-fill: #a5a5a5; -fx-font-size: 15px; -fx-alignment: center;" />

                <Label text="Daily Streak" textAlignment="CENTER" maxWidth="1.7976931348623157E308"
                       style="-fx-text-fill: #f15e67; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: center;" />
                <StackPane prefWidth="122" prefHeight="122">
                    <Pane prefWidth="122" prefHeight="122" maxWidth="122" maxHeight="122">
                        <children>
                            <Circle centerX="61" centerY="61" radius="52" fill="transparent" stroke="#4f4f4f" strokeWidth="8" />
                            <Arc type="OPEN" centerX="61" centerY="61" radiusX="52" radiusY="52" startAngle="90" length="-144"
                                 fill="transparent" stroke="#f15e67" strokeWidth="8" strokeLineCap="ROUND" />
                        </children>
                    </Pane>
                    <Label text="2" style="-fx-text-fill: #f15e67; -fx-font-size: 44px; -fx-font-weight: bold;" />
                </StackPane>

                <VBox spacing="2" alignment="CENTER">
                    <Label text="Longest Streak" style="-fx-text-fill: #f0f0f0; -fx-font-size: 15px;" />
                    <Label text="295 Days" style="-fx-text-fill: #f15e67; -fx-font-size: 16px; -fx-font-weight: bold;" />
                </VBox>

                <VBox spacing="2" alignment="CENTER">
                    <Label text="Completed Questions" style="-fx-text-fill: #f0f0f0; -fx-font-size: 15px;" />
                    <Label text="0" style="-fx-text-fill: #f15e67; -fx-font-size: 16px; -fx-font-weight: bold;" />
                </VBox>
            </VBox>
        </VBox>
    </right>
</BorderPane>
