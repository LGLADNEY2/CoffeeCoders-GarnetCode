<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<BorderPane fx:id="dashboardRoot" xmlns:fx="http://javafx.com/fxml" fx:controller="com.controllers.DashboardController">
    <!-- Sidebar -->
    <left>
        <VBox spacing="20" prefWidth="180" alignment="TOP_CENTER" BorderPane.alignment="CENTER"
              style="-fx-background-color: #a82525; -fx-background-radius: 18px; -fx-padding: 24 0 24 0;">
            <Label text="GARNETCODE" style="-fx-text-fill: #fff; -fx-font-size: 22px; -fx-font-weight: bold; -fx-padding: 0 0 18 0;" />
            <VBox spacing="10">
                <Button text="Dashboard" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 10 0 10 18; -fx-background-radius: 8px; -fx-cursor: hand;" />
                <Button text="Favorites" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 10 0 10 18; -fx-background-radius: 8px; -fx-cursor: hand;" />
                <Button text="Questions" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 10 0 10 18; -fx-background-radius: 8px; -fx-cursor: hand;" />
                <Button text="Create" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 10 0 10 18; -fx-background-radius: 8px; -fx-cursor: hand;" onAction="#goToCreate" />
            </VBox>
        </VBox>
    </left>
    <!-- Main Content -->
    <center>
          <VBox spacing="20" alignment="TOP_CENTER"
              style="-fx-background-color: #23201e; -fx-background-radius: 18px; -fx-padding: 32 32 32 32; -fx-effect: dropshadow(gaussian, #00000055, 16, 0.2, 0, 4);">
            <!-- Top Bar -->
            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: transparent; -fx-padding: 0 0 18 0;">
                <TextField promptText="Search for problems here..." style="-fx-background-color: #a82525; -fx-text-fill: #fff; -fx-font-size: 16px; -fx-background-radius: 24px; -fx-padding: 8 18 8 18; -fx-prompt-text-fill: #fff8; -fx-border-width: 0;" />
                <Button style="-fx-background-color: #a82525; -fx-background-radius: 24px; -fx-text-fill: #fff; -fx-font-size: 20px; -fx-padding: 8 16 8 16; -fx-cursor: hand;">
                    <Label text="🔍" />
                </Button>
            </HBox>
            <!-- Sections -->
            <VBox spacing="20" styleClass="sections">
                <!-- Continue Section -->
                <VBox spacing="10" styleClass="section">
                    <Label text="Continue" styleClass="section-title" />
                    <TableView fx:id="continueTable" styleClass="problem-table">
                        <columns>
                            <TableColumn fx:id="colTitleDate" text="Problem Title / Date" />
                            <TableColumn fx:id="colCategory" text="Category" />
                            <TableColumn fx:id="colLanguage" text="Language" />
                            <TableColumn fx:id="colClass" text="Class" />
                            <TableColumn fx:id="colDifficulty" text="Difficulty" />
                            <TableColumn fx:id="colRating" text="Rating" />
                        </columns>
                    </TableView>
                </VBox>
                <!-- Recommended Section -->
                <VBox spacing="10" styleClass="section">
                    <Label text="Recommended" styleClass="section-title" />
                    <TableView fx:id="recommendedTable" styleClass="problem-table">
                        <columns>
                            <TableColumn fx:id="colTitleDate" text="Problem Title / Date" />
                            <TableColumn fx:id="colCategory" text="Category" />
                            <TableColumn fx:id="colLanguage" text="Language" />
                            <TableColumn fx:id="colClass" text="Class" />
                            <TableColumn fx:id="colDifficulty" text="Difficulty" />
                            <TableColumn fx:id="colRating" text="Rating" />
                        </columns>
                    </TableView>
                </VBox>
                <!-- Favorites Section -->
                <VBox spacing="10" styleClass="section">
                    <Label text="Favorites" styleClass="section-title" />
                    <TableView fx:id="favoritesTable" styleClass="problem-table">
                        <columns>
                            <TableColumn fx:id="colTitleDate" text="Problem Title / Date" />
                            <TableColumn fx:id="colCategory" text="Category" />
                            <TableColumn fx:id="colLanguage" text="Language" />
                            <TableColumn fx:id="colClass" text="Class" />
                            <TableColumn fx:id="colDifficulty" text="Difficulty" />
                            <TableColumn fx:id="colRating" text="Rating" />
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </VBox>
    </center>
    <!-- Profile Panel -->
    <right>
        <VBox spacing="20" alignment="TOP_CENTER" prefWidth="250"
              style="-fx-background-color: #23201e; -fx-background-radius: 18px; -fx-padding: 32 0 32 0; -fx-effect: dropshadow(gaussian, #00000055, 16, 0.2, 0, 4);">
            <ImageView fx:id="profileImage" fitWidth="80" fitHeight="80" style="-fx-background-radius: 40px; -fx-effect: dropshadow(gaussian, #a82525, 8, 0.2, 0, 2);" />
            <Label text="Good Morning, Cocky!" style="-fx-text-fill: #fff; -fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 8 0 0 0;" />
            <Label text="Continue Your Journey And\nAchieve Your Target" style="-fx-text-fill: #bdbdbd; -fx-font-size: 13px; -fx-padding: 0 0 12 0;" />
            <HBox spacing="10" alignment="CENTER">
                <Button style="-fx-background-color: #181716; -fx-background-radius: 50%; -fx-text-fill: #fff; -fx-font-size: 18px; -fx-padding: 8 8 8 8; -fx-cursor: hand;" />
                <Button style="-fx-background-color: #181716; -fx-background-radius: 50%; -fx-text-fill: #fff; -fx-font-size: 18px; -fx-padding: 8 8 8 8; -fx-cursor: hand;" />
                <Button style="-fx-background-color: #181716; -fx-background-radius: 50%; -fx-text-fill: #fff; -fx-font-size: 18px; -fx-padding: 8 8 8 8; -fx-cursor: hand;" />
            </HBox>
            <VBox spacing="10" alignment="CENTER">
                <Label text="Daily Streak" style="-fx-text-fill: #fff; -fx-font-size: 14px; -fx-font-weight: bold;" />
                <ProgressBar fx:id="streakBar" progress="0.2" style="-fx-accent: #a82525; -fx-background-radius: 8px; -fx-pref-height: 8px;" />
                <Label text="2" style="-fx-text-fill: #a82525; -fx-font-size: 22px; -fx-font-weight: bold;" />
            </VBox>
            <Label text="Longest Streak\n295 Days" style="-fx-text-fill: #fff; -fx-font-size: 14px; -fx-padding: 6 0 0 0;" />
            <Label text="Completed Questions\n0" style="-fx-text-fill: #fff; -fx-font-size: 14px; -fx-padding: 6 0 0 0;" />
        </VBox>
    </right>
</BorderPane>
